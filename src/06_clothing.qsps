		act 'Shoes': gs 'mod_GLQS_main', 'fill_shoe', 'bomba' & gt 'mod_GLQS_main', 'store_detail', 'bomba'
		act 'Coats': gs 'mod_GLQS_main', 'fill_coat', 'bomba' & gt 'mod_GLQS_main', 'store_detail', 'bomba'
