		act 'Outfits': gs 'mod_GLQS_main', 'fill_clo', 'eroto_outfits' & gt 'mod_GLQS_main', 'store_detail', 'eroto'
		act 'Dresses': gs 'mod_GLQS_main', 'fill_clo', 'eroto_dress' & gt 'mod_GLQS_main', 'store_detail', 'eroto'
		act 'Strip Outfits': gs 'mod_GLQS_main', 'fill_clo', 'eroto_strip' & gt 'mod_GLQS_main', 'store_detail', 'eroto'
		act 'Shoes': gs 'mod_GLQS_main', 'fill_shoe', 'eroto' & gt 'mod_GLQS_main', 'store_detail', 'eroto'
		act 'Bras': gs 'mod_GLQS_main', 'fill_bra', 'eroto' & gt 'mod_GLQS_main', 'store_detail', 'eroto'
		act 'Panties': gs 'mod_GLQS_main', 'fill_panty', 'eroto' & gt 'mod_GLQS_main', 'store_detail', 'eroto'
	end
	if $glqs_store = 'lusso':
		act 'Bras': gs 'mod_GLQS_main', 'fill_bra', 'lusso' & gt 'mod_GLQS_main', 'store_detail', 'lusso'
		act 'Panties': gs 'mod_GLQS_main', 'fill_panty', 'lusso' & gt 'mod_GLQS_main', 'store_detail', 'lusso'
		act 'Bodysuits': gs 'mod_GLQS_main', 'fill_body', 'lusso' & gt 'mod_GLQS_main', 'store_detail', 'lusso'
	end
	if $glqs_store = 'misc':
		act 'Misc Items': gs 'mod_GLQS_main', 'fill_clo', 'misc' & gt 'mod_GLQS_main', 'store_detail', 'misc'
	end

	*nl
	act 'Buy All (this store)': gs 'mod_GLQS_main', 'store_buy', $glqs_store & gt 'mod_GLQS_main', 'store_detail', $glqs_store
	act 'Return': gt 'mod_GLQS_main', 'store_menu'
end


