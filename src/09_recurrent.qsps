	*nl

	act 'Enable All':
		gs 'mod_GLQS_main', 'recurrent_on'
		gt 'mod_GLQS_main', 'recurrent'
	end

	act 'Disable All':
		gs 'mod_GLQS_main', 'recurrent_off'
		gt 'mod_GLQS_main', 'recurrent'
	end

	act 'Return': gt 'mod_GLQS_main', 'start'
end


