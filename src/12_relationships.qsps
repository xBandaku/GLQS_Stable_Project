!! RELATIONSHIPS SUBMENU + MAX_CATEGORY DISPATCHER
!! Roster is one flat pipe-delimited array shared by rel_menu (render) and
!! max_category (maxing) so the two lists can never drift apart - each entry
!! is category|gender|npc_rel_key|display_name. gender matches
!! glqs_rel_filter (1=male, 2=female). QSP has no split function, so entries
!! are parsed with instr/mid below, the same technique the base game itself
!! uses (see mid(ARGS[0], 1, instr(ARGS[0], space) - 1) in its source).
if $ARGS[0] = 'rel_menu' or $ARGS[0] = 'max_category':
	$glqs_cat_label['family'] = 'Family'
	$glqs_cat_label['popular'] = 'Popular Kids'
	$glqs_cat_label['athletes'] = 'Athletes'
	$glqs_cat_label['nerds'] = 'Nerds'
	$glqs_cat_label['gopniks'] = 'Gopniks'
	$glqs_cat_label['outcasts'] = 'Outcasts'
	$glqs_cat_label['teachers'] = 'Teachers'
	$glqs_cat_label['others'] = 'Others'

	glqs_n = 0
	$glqs_npc[glqs_n] = 'family|1|A28|Dad (M)' & glqs_n += 1
	$glqs_npc[glqs_n] = 'family|2|A29|Mother (F)' & glqs_n += 1
	$glqs_npc[glqs_n] = 'family|2|A33|Sister (F)' & glqs_n += 1
