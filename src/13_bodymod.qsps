end


if $ARGS[0] = 'piercing_design_menu':
	!! ARGS[1] = slot name. Captured before any nested gs call - $ARGS is one
	!! shared array in QSP, not scoped per gosub, so calling gs stat / gs
	!! themes below would clobber ARGS[1] before we get to read it.
	$glqs_slot = $ARGS[1]
	menu_off = 0
	usehtml = 1
	$location_type = 'event'
	gs 'stat'
	gs 'themes', 'indoors'
	!! Same nightly-only get_total name as tattoo_design_menu above - Girl
	!! Life stable 0.9.8.3 only has a totals gosub that returns via
	!! result. total = 0 first, then fall back to result only if totals
	!! left total untouched (stable) rather than setting it directly
	!! (nightly).
	total = 0
	gs 'piercing_management', 'totals', $glqs_slot
	if total <= 0: total = result
	'<center><b><font color="maroon">Piercing Jewelry: <<$glqs_slot>></font></b></center>'
	'<br><<total>> designs available. Click an image to apply it.'
	*nl
	$glqs_grid = '<div style="display:flex; flex-wrap:wrap; gap:8px;">'
	glqs_i = 1
	:glqs_pierce_img_loop
	if glqs_i <= total:
		$glqs_grid += '<div style="flex:0 0 auto;"><a href="exec: gs ''piercing_management'', ''add'', ''<<$glqs_slot>>'', <<glqs_i>> & gs ''stat'' & gt ''mod_GLQS_main'', ''piercing_design_menu'', ''<<$glqs_slot>>''"><img height="220" src="<<func(''piercing_management'', $glqs_slot + ''_image'', glqs_i)>>"></a></div>'
		glqs_i += 1
		jump 'glqs_pierce_img_loop'
	end
	killvar 'glqs_i'
	$glqs_grid += '</div>'
	$glqs_grid
	*nl

	if pcs_piercings[$glqs_slot] > 0:
		act 'Remove Piercing From This Slot':
			gs 'piercing_management', 'remove', $glqs_slot
			gs 'stat'
			gt 'mod_GLQS_main', 'piercing_design_menu', $glqs_slot
		end
	end

	!! $glqs_slot is NOT killed here - the act above references it directly,
	!! and QSP resolves act bodies at click time, not at definition time.
	!! Killing it here would clear it before the player could ever click,
	!! same stray-killvar bug as fame_detail (see comment there).
	act 'Back to Slots': gt 'mod_GLQS_main', 'piercing_slot_menu'
	act 'Return to Top Menu': gt 'mod_GLQS_main', 'start'
end
