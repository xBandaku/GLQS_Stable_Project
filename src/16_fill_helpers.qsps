if $ARGS[0] = 'clo_full_h':
	!! Full/max durability for a clo item. Must run immediately after
	!! gs clothing_attributes, key, index for the same item, since
	!! it depends on the CloQuality/CloStyle/CloMaxStrength that call
	!! just set. Nightly computes CloMaxStrength itself inside
	!! clothing_attributes; Girl Life stable 0.9.8.3 has no such
	!! variable at all (referencing it there silently reads 0, so every
	!! clo item this mod grants ended up with 0 durability - shown
	!! in-wardrobe as worn and not suitable for further wear). Stable
	!! instead computes durability once, at initial purchase time, from
	!! a category-name formula inside clothing.qsrcs add_clothing -
	!! mirrored here as the fallback when CloMaxStrength reads 0.
	!! $ARGS[1] = category key (e.g. cats_outfits)
	if CloMaxStrength > 0:
		glqs_h = CloMaxStrength
	else
		glqs_h = 3 * CloQuality
		if CloStyle = 2: glqs_h += 10
		if CloStyle = 5: glqs_h += 20
		if instr(';gm_outfits;gm_dress;gm_office;', ';' + $ARGS[1] + ';') > 0:
			glqs_h += 70
		elseif instr($ARGS[1], 'gm') > 0:
			glqs_h += 120
		elseif instr($ARGS[1], 'cats') > 0 or instr($ARGS[1], 'flamingos') > 0 or instr($ARGS[1], 'coco') > 0 or instr(';nerdvana_cosplay;nerdvana_outfits;', ';' + $ARGS[1] + ';') > 0:
			glqs_h += 90
		elseif instr($ARGS[1], 'moncheri') > 0:
			glqs_h += 25
		elseif instr($ARGS[1], 'eroto') > 0 or instr($ARGS[1], 'salacious') > 0 or $ARGS[1] = 'fancy_burlesque':
			glqs_h += 40
		elseif $ARGS[1] = 'danilovich_outfits':
			glqs_h += 100
		else
			glqs_h += 60
		end
	end
end

if $ARGS[0] = 'coat_full_h':
	!! Full/max durability for a coat item. Must run immediately after
	!! gs coat_attributes, key, index for the same item, since it
	!! depends on the CoatMaxStrength that call just set. Girl Life
	!! stable 0.9.8.3 has no such variable and always grants coats at a
	!! flat 240 durability on purchase (coats.qsrc) - mirrored here as
	!! the fallback when CoatMaxStrength reads 0.
	if CoatMaxStrength > 0:
		glqs_h = CoatMaxStrength
	else
		glqs_h = 240
	end
end

if $ARGS[0] = 'sho_full_h':
	!! Full/max durability for a shoe item. Unlike clo/coat, Girl Life
	!! stable 0.9.8.3 has no durability tracking for shoes at all - no
	!! _shoe_h array is ever read anywhere in stable, so the nightly-only
	!! ShoMaxStrength reading 0 there was already harmless (dead data,
	!! not a visible bug). Made explicit here instead of relying on an
	!! undefined variable silently defaulting to 0, so this reads the
	!! same as clo_full_h/coat_full_h rather than looking like a missed
	!! case.
	if ShoMaxStrength > 0:
		glqs_h = ShoMaxStrength
	else
		glqs_h = 0
	end
end

if $ARGS[0] = 'bra_full_h':
	!! Same as sho_full_h above, for bras - stable has no _bras_h reads.
	if BraMaxStrength > 0:
		glqs_h = BraMaxStrength
	else
		glqs_h = 0
	end
end

if $ARGS[0] = 'pan_full_h':
	!! Same as sho_full_h above, for panties - stable has no
	!! _panties_h reads.
	if PanMaxStrength > 0:
		glqs_h = PanMaxStrength
	else
		glqs_h = 0
	end
end

if $ARGS[0] = 'body_full_h':
	!! Same as sho_full_h above, for bodysuits - stable has no
	!! _bodysuits_h reads. Reuses BraMaxStrength, matching fill_bodys
	!! existing convention that bodysuit durability shares bras
	!! attribute naming.
	if BraMaxStrength > 0:
		glqs_h = BraMaxStrength
	else
		glqs_h = 0
	end
end
