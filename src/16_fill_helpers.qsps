!! FILL HELPERS: per-category item granting loops
if $ARGS[0] = 'fill_clo':
	!! set_shop_display_exceptions + the arrpos guard below skip a handful
	!! of indices the base games own shop hides from every category (e.g.
	!! danilovich_outfits 161/162, cats_dress 221) - these are dead slots
	!! with no real image behind them, so granting them anyway showed up
	!! as blank images in the wardrobe list.
	$glqs_fc_key = $ARGS[1]
	gs 'clothing', 'totals', $glqs_fc_key
	gs 'clothing', 'set_shop_display_exceptions', $glqs_fc_key
	glqs_i = 1
	:glqs_clo_loop
	if glqs_i <= total:
		if arrpos('shop_display_exceptions', glqs_i) < 0:
			dyneval('<<$glqs_fc_key>>[glqs_i] = 1')
			gs 'clothing_attributes', $glqs_fc_key, glqs_i
			gs 'mod_GLQS_main', 'clo_full_h', $glqs_fc_key
			dyneval('<<$glqs_fc_key>>_h[glqs_i] = glqs_h')
		end
		glqs_i += 1
		jump 'glqs_clo_loop'
	end
	killvar 'glqs_i'
	killvar '$glqs_fc_key'
end

